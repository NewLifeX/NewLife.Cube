@model EntityField
@using NewLife;
@using NewLife.Cube
@using XCode;
@using XCode.Configuration;
@{
    var entity = Model.Entity;
    var field = Model.Field;

    var err = 0;
    if (ViewData.ModelState.TryGetValue(field.Name, out var st) && st != null) { err = st.Errors.Count; }

    var des = field.Description.TrimStart(field.DisplayName).TrimStart(",", ".", "，", "。");
}
<label class="control-label col-xs-12 col-sm-2 col-lg-1 text-ellipsis" title="@field.DisplayName">@field.DisplayName</label>

@if (err > 0)
{
    <span class="col-xs-12 col-sm-10 col-lg-11 alert alert-danger">
        @Html.ValidationMessage(field.Name)
    </span>
}
else if (!des.IsNullOrEmpty())
{
    <span class="col-xs-12 col-sm-10 col-lg-11 text-ellipsis" title="@des"><span class="middle">@des</span></span>
}

<div class="input-group col-xs-12 col-sm-10 col-lg-11">
    @if (field.ReadOnly)
    {
        <div class="form-control" style="height:auto;min-height:150px;overflow:auto;padding:8px">@Html.Raw(entity[field.Name] + "")</div>
        <input type="hidden" name="@field.Name" value="@(entity[field.Name] + "")" />
    }
    else
    {
        @await Html.PartialAsync("_HtmlEditor", new ItemModel(field.Name, entity[field.Name], field.Type))
    }
</div>

