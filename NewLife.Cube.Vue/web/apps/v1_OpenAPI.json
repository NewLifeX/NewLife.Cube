            "name": "scope",
            "in": "query",
            "description": "授权域",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "description": "用户状态数据",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "loginUrl",
            "in": "query",
            "description": "登录页。子系统请求SSO时，如果在SSO未登录则直接跳转的地址，该地址有可能属于子系统自身，适用于password模式登录等场景",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "operationId": "59d27138efbc354f03fe6615f88d6ceb"
      }
    },
