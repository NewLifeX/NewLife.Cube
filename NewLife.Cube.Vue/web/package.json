{
  "name": "@newlifex/cube-vue",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:e2e": "cypress run --e2e",
    "test:e2e:dev": "cypress open --e2e",
    "test:component": "cypress run --component --browser chrome",
    "test:component:dev": "cypress open --component --browser chrome",
    "build:plugin": "set BUILD_TARGET=plugin&& vite build",
    "type-check": "vue-tsc --build",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path .gitignore",
    "lint:eslint": "eslint . --fix",
    "lint": "run-s lint:*",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@cube/api-core": "workspace:*",
    "@element-plus/icons-vue": "^2.3.1",
    "@vueuse/core": "^13.0.0",
    "axios": "^1.18.0",
    "dayjs": "^1.11.21",
    "echarts": "^5.6.0",
    "lodash": "^4.17.21",
    "query-string": "^9.1.1",
    "universal-cookie": "^8.0.1",
    "vanilla-jsoneditor": "^2.2.2",
    "@wangeditor/editor": "^5.1.23",
    "@wangeditor/editor-for-vue": "^5.1.12",
    "md-editor-v3": "^4.19.1",
    "vue-echarts": "^7.0.3"
  },
  "peerDependencies": {
    "element-plus": "^2.9.7",
    "pinia": "^3.0.1",
    "vue": "^3.5.13",
    "vue-i18n": "^11.4.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tsconfig/node22": "^22.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/lodash": "^4.17.9",
    "@types/node": "^22.13.9",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitejs/plugin-vue-jsx": "^4.1.1",
    "@vitest/eslint-plugin": "^1.1.36",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/reactivity": "^3.5.13",
    "@vue/runtime-dom": "^3.5.13",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.20",
    "code-inspector-plugin": "^1.5.1",
    "cypress": "^14.1.0",
    "eslint": "^9.21.0",
    "eslint-import-resolver-typescript": "^4.3.2",
    "eslint-plugin-cypress": "^4.2.0",
    "eslint-plugin-oxlint": "^0.15.13",
    "eslint-plugin-vue": "~10.0.0",
    "jiti": "^2.4.2",
    "jsdom": "^29.0.0",
    "npm-run-all2": "^7.0.2",
    "oxlint": "^0.15.13",
    "postcss": "^8.5.3",
    "prettier": "3.5.3",
    "sass": "^1.86.3",
    "sass-loader": "^16.0.5",
    "start-server-and-test": "^2.0.10",
    "tailwindcss": "^4.1.3",
    "typescript": "~5.8.2",
    "unplugin-auto-import": "^19.1.2",
    "unplugin-vue-components": "^28.5.0",
    "vite": "^6.2.1",
    "vite-plugin-vue-devtools": "^7.7.2",
    "vitest": "^3.0.8",
    "vue-tsc": "^2.2.8"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  }
}